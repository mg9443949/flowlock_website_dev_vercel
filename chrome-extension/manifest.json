{
  "manifest_version": 3,
  "name": "FlowLock",
  "version": "1.0",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://flowlock-website-dev-vercel.vercel.app/*",
    "https://cutgjwfkgkoynmxpsntr.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://flowlock-website-dev-vercel.vercel.app/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "FlowLock"
  }
}